# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Required for the /api/analyze-car endpoint (Gemini + Google Search Grounding).
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production.
STRIPE_SECRET_KEY="sk_test_..."
# Webhook signing secret from https://dashboard.stripe.com/webhooks
# (After creating a webhook endpoint pointing to https://yourdomain.com/api/stripe-webhook)
STRIPE_WEBHOOK_SECRET="whsec_..."

# Checkout mode: "hosted" (default) or "embedded" (TikTok In-App-Browser safe).
# Server-side flag — controls whether /api/create-checkout returns a redirect URL
# (hosted) or a client_secret (embedded).
CHECKOUT_MODE="hosted"

# ─── Stripe Frontend (browser bundle) ─────────────────────────────────────────
# Publishable key from https://dashboard.stripe.com/apikeys (NOT the secret key!)
# Must be prefixed with VITE_ to be exposed to the browser bundle by Vite.
# Use pk_test_... for testing, pk_live_... for production.
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Checkout mode: "hosted" (default) or "embedded" (TikTok In-App-Browser safe).
# Frontend flag — controls whether the React UI mounts an EmbeddedCheckout iframe
# or stays on the form and does a top-level redirect on submit.
VITE_CHECKOUT_MODE="hosted"

# ─── PayPal (browser bundle) ────────────────────────────────────────────────
# Sandbox client ID from https://developer.paypal.com/dashboard/applications
# (NOT the secret, the public ID).
# Must be prefixed with VITE_ to be exposed to the browser bundle.
VITE_PAYPAL_CLIENT_ID=""

# Optional. Defaults to "sandbox". Set to "production" only for live deployments.
VITE_PAYPAL_ENVIRONMENT="sandbox"

# ─── E-Mail (Nodemailer) ──────────────────────────────────────────────────────
# Option A: Gmail — use an App Password (not your regular Gmail password):
#   https://myaccount.google.com/apppasswords
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="yourname@gmail.com"
# SMTP_PASS="your-16-char-app-password"

# Option B: Resend.com (recommended, cleaner setup, 3k emails/month free):
#   https://resend.com/api-keys
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER="resend"
# SMTP_PASS="re_your_resend_api_key"

SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# ─── Owner ────────────────────────────────────────────────────────────────────
# The email address that receives new order notifications.
OWNER_EMAIL="owner@yourdomain.com"

# ─── App ──────────────────────────────────────────────────────────────────────
# OPTIONAL: Public URL of the app. Used for Stripe success/cancel/return URLs.
# Priority: APP_URL → https://${VERCEL_URL} → request-origin (if allowlisted).
# If unset, the backend derives the origin from the Vercel-provided VERCEL_URL
# or from the request's host header (only for *.vercel.app or ALLOWED_HOSTS).
# Set this only if you want a fixed production origin (e.g. custom domain).
# APP_URL="https://timos-autoberatung.de"

# OPTIONAL: Comma-separated list of additional allowed hosts for the request-origin
# fallback (e.g. custom production domains). Use only for production setup.
# Hosts NOT matching *.vercel.app and NOT in this list will be REJECTED for Stripe
# return URLs to prevent open-redirect abuse.
# ALLOWED_HOSTS="timos-autoberatung.de,www.timos-autoberatung.de"

# ─── PayPal (server-side) ────────────────────────────────────────────────────
# Sandbox-Live-Schalter. "sandbox" zeigt auf api-m.sandbox.paypal.com,
# "production" auf api-m.paypal.com. Default: "sandbox".
PAYPAL_ENVIRONMENT="sandbox"

# Sandbox-Live-Paar aus https://developer.paypal.com/dashboard/applications
# (REST API App erstellen, dann "Client ID" + "Secret" kopieren).
# Diese sind SERVER-SIDE Credentials, NICHT mit VITE_ prefixen.
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
