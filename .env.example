# Gemini AI, used by POST /api/analyze-car.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional Exa grounding for vehicle specs/problem research.
EXA_API_KEY=""

# Optional safety switch and explicit low-cost model selection for the public AI check.
AI_ANALYSIS_ENABLED=true
GEMINI_ANALYSIS_MODEL="gemini-3.1-flash-lite"

# Stripe payments.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Vercel injects BLOB_READ_WRITE_TOKEN after connecting the private Stripe outbox.
# Do not copy a production Blob token into this file.

# SMTP mail delivery for contract confirmations and withdrawal receipts.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="orders@yourdomain.com"

# Owner receives paid-order details and withdrawal notifications.
OWNER_EMAIL="owner@yourdomain.com"

# Public operator contact printed in contract and withdrawal emails.
OPERATOR_NAME="Enricha Einzelunternehmen, Timo Bieker"
OPERATOR_ADDRESS="c/o Postflex #10093, Emsdettener Str. 10, 48268 Greven"
OPERATOR_EMAIL="enricha@web.de"
SUPPORT_EMAIL="support@enricha.de"

# Public app origin used for Stripe success/cancel URLs.
APP_URL="http://localhost:3000"

# Local backend port for npm run server / server:dev.
PORT=3001
