# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Required for the /api/analyze-car endpoint (Gemini + Google Search Grounding).
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production.
STRIPE_SECRET_KEY="sk_test_..."
# Webhook signing secret from https://dashboard.stripe.com/webhooks
# (After creating a webhook endpoint pointing to https://yourdomain.com/api/stripe-webhook)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── E-Mail (Nodemailer) ──────────────────────────────────────────────────────
# Option A: Gmail — use an App Password (not your regular Gmail password):
#   https://myaccount.google.com/apppasswords
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="yourname@gmail.com"
# SMTP_PASS="your-16-char-app-password"

# Option B: Resend.com (recommended, cleaner setup, 3k emails/month free):
#   https://resend.com/api-keys
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER="resend"
# SMTP_PASS="re_your_resend_api_key"

SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# ─── Owner ────────────────────────────────────────────────────────────────────
# The email address that receives new order notifications.
OWNER_EMAIL="owner@yourdomain.com"

# ─── App ──────────────────────────────────────────────────────────────────────
# The public URL of the app. Used for Stripe success/cancel redirect URLs.
APP_URL="http://localhost:3000"
